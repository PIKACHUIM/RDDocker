ARG OS_VERSION=3.20
ARG OS_SYSTEMS=alpine
ARG OS_VERSHOW=3.20
FROM pikachuim/${OS_SYSTEMS}:${OS_VERSHOW}-x11gui
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Alpine with Plasma Desktop"
LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY --chmod=755 Scripts/Install/ /install/
RUN /install/Desktop/plasma.sh

EXPOSE 4000/tcp
CMD ["/bin/sh", "/run.sh"]
