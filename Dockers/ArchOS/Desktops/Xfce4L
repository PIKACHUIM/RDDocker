ARG OS_VERSION=latest
ARG OS_SYSTEMS=archlinux
ARG OS_VERSHOW=latest
FROM pikachuim/${OS_SYSTEMS}:${OS_VERSHOW}-x11gui
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Arch Linux with Xfce4L Desktop"
ARG INSTALL_FIREFOX=false
ARG INSTALL_CHROME=false
ARG INSTALL_VSCODE=false
ARG INSTALL_QQ=false

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY Scripts/Install/ /install/
RUN /install/Desktop/xfce4l.sh
RUN INSTALL_FIREFOX=${INSTALL_FIREFOX} INSTALL_CHROME=${INSTALL_CHROME}     INSTALL_VSCODE=${INSTALL_VSCODE} INSTALL_QQ=${INSTALL_QQ}     /install/software.sh

EXPOSE 4000/tcp
CMD ["/sbin/init"]
