ARG OS_VERSION=bookworm
ARG OS_SYSTEMS=debian
FROM debian:${OS_VERSION}
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Debian with OpenSSH Server"

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY --chmod=755 Scripts/Install/ /install/
RUN /install/mirrors.sh && /install/server.sh

EXPOSE 22/tcp
CMD ["/sbin/init"]
