ARG OS_VERSION=bookworm
ARG OS_SYSTEMS=debian
ARG OS_VERSHOW=bookworm
FROM pikachuim/${OS_SYSTEMS}:${OS_VERSHOW}-x11gui
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Debian with GNOME3 Desktop"
LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY --chmod=755 Scripts/Install/ /install/
RUN /install/Desktop/gnome3.sh

EXPOSE 4000/tcp
CMD ["/sbin/init"]
