ARG OS_VERSION=42
ARG OS_SYSTEMS=fedora
ARG OS_VERSHOW=42
FROM pikachuim/${OS_SYSTEMS}:${OS_VERSHOW}-server
ARG OS_MESSAGE="Fedora with X11 + NoMachine + VNC + XRDP"

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY Scripts/Install/ /install/
RUN /install/x11gui.sh && /install/wayland.sh

EXPOSE 4000/tcp 5900/tcp 3389/tcp
CMD ["/sbin/init"]
