ARG OS_VERSION=latest
ARG OS_SYSTEMS=archlinux
FROM archlinux:${OS_VERSION}
ARG OS_MESSAGE="Arch Linux with OpenSSH Server"

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY Scripts/Install/ /install/
RUN chmod -R +x /install && /install/mirrors.sh && /install/server.sh

EXPOSE 22/tcp
CMD ["/sbin/init"]
