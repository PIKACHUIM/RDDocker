ARG OS_VERSION=42
ARG OS_SYSTEMS=fedora
FROM fedora:${OS_VERSION}
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Fedora with OpenSSH Server"

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY --chmod=755 Scripts/Install/ /install/
RUN chmod -R +x /install && /install/mirrors.sh && /install/server.sh

EXPOSE 22/tcp
CMD ["/sbin/init"]
