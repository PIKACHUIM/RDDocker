ARG OS_SYSTEMS=archos
FROM pikachuim/${OS_SYSTEMS}:latest-server
ARG OS_SYSTEMS
ARG OS_MESSAGE="ArchOS with X11 + VNC + XRDP"
LABEL System=${OS_SYSTEMS} Version=latest Description=${OS_MESSAGE}
COPY --chmod=755 scripts/install/ /install/
RUN /install/x11core.sh && /install/wayland.sh

EXPOSE 4000/tcp 5900/tcp 3389/tcp
CMD ["/bin/sh", "/run.sh"]
