ARG OS_VERSION=3.24.1
ARG OS_SYSTEMS=alpine
FROM alpine:${OS_VERSION}
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Alpine with OpenSSH Server"

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY --chmod=755 Scripts/Install/ /install/
RUN /install/mirrors.sh && /install/server.sh

EXPOSE 22/tcp
CMD ["/bin/sh", "/run.sh"]
