ARG OS_VERSION=latest
ARG OS_SYSTEMS=archlinux
ARG OS_VERSHOW=latest
FROM pikachuim/${OS_SYSTEMS}:${OS_VERSHOW}-server
ARG OS_VERSION
ARG OS_SYSTEMS
ARG OS_MESSAGE="Arch Linux with X11 + VNC + XRDP"

LABEL System=${OS_SYSTEMS} Version=${OS_VERSION} Description=${OS_MESSAGE}
COPY --chmod=755 Scripts/Install/ /install/
RUN /install/x11gui.sh && /install/wayland.sh

EXPOSE 4000/tcp 5900/tcp 3389/tcp
CMD ["/sbin/init"]
